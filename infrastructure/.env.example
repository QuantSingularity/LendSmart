# ── LendSmart Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Database
MYSQL_ROOT_PASSWORD=change_me_strong_root_password
MYSQL_DATABASE=lendsmartdb
MYSQL_USER=appuser
MYSQL_PASSWORD=change_me_strong_app_password

# Backend secrets
JWT_SECRET=change_me_to_a_long_random_string_at_least_64_chars
API_KEY=change_me_api_key

# AWS (only needed for Terraform; use IAM roles in EC2/ECS instead)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-west-2
